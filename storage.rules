rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos — any authenticated user can upload their own photo
    // and any authenticated user can read any profile photo
    match /profile_photos/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && filename.matches(request.auth.uid + '\\.jpg');
    }
  }
}
