rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — any authenticated user can read (needed for member resolution & matching)
    // The owner has full write access to their own profile.
    // Any authenticated user can update only the groupIds field on another
    // user's document (needed when a group admin adds a member).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
      allow update: if request.auth != null
                   && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['groupIds']);
    }

    // Groups — any authenticated user can read
    // Members can update; a non-member can also update if they are adding
    // themselves to memberIds (i.e. accepting an invite / joining).
    // Only admin can delete.
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.memberIds
                        || request.auth.uid in request.resource.data.memberIds);
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.adminId;

      // Discussions — any authenticated user can read/create
      // (group access is already gated at the app level via groupsProvider)
      match /discussions/{discussionId} {
        allow read, create, update: if request.auth != null;
        allow delete: if request.auth != null
                      && request.auth.uid == resource.data.authorId;

        // Replies
        match /replies/{replyId} {
          allow read, create: if request.auth != null;
          allow delete: if request.auth != null
                        && request.auth.uid == resource.data.authorId;
        }
      }

      // Sessions — members only
      match /sessions/{sessionId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
        allow create, update: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        // Attendance — each user marks their own only
        match /attendance/{userId} {
          allow read, write: if request.auth != null
                             && request.auth.uid == userId;
        }
      }
    }

    // Match requests — sender or receiver can read
    match /matchRequests/{requestId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.senderId
                  ||  request.auth.uid == resource.data.receiverId);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.receiverId;
    }

    // Notifications — recipient can read/update, any auth user can create
    match /notifications/{notifId} {
      allow read, update: if request.auth != null
                          && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}

